{
   "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "includes": ["./src/**", "./*.ts", "./*.js", "./*.json"],
      "ignoreUnknown": false
   },
   "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 3,
      "lineWidth": 100,
      "attributePosition": "multiline"
   },
   "linter": {
      "enabled": true,
      "rules": {
         "recommended": true
      }
   },
   "javascript": {
      "jsxRuntime": "transparent",
      "formatter": {
         "quoteStyle": "double",
         "semicolons": "always",
         "operatorLinebreak": "after"
      }
   },
   "css": {
      "parser": {
         "tailwindDirectives": true
      }
   },
   "assist": {
      "enabled": true,
      "actions": {
         "source": {
            "organizeImports": "on"
         }
      }
   }
}
